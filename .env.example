# =====================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env.local and fill in your values
# =====================================================

# SUPABASE CONFIGURATION
# Get these values from your Supabase project dashboard
# https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# BACKEND SERVICES
# Chat API - Supabase Edge Function
# Endpoint: {VITE_SUPABASE_URL}/functions/v1/chat
# Auth API - Supabase Auth
# Endpoint: {VITE_SUPABASE_URL}/auth/v1
# Real-time API - Supabase Realtime
# Endpoint: wss://{VITE_SUPABASE_URL}/realtime/v1

# NOTES
# - All VITE_* variables are exposed to the frontend (safe public keys only)
# - Keep your .env.local secure and never commit to git
# - For Vercel: Set these same variables in project Settings > Environment Variables
# - Ensure Supabase CORS allows your deployment domain
